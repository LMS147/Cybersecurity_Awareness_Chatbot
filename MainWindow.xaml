<Window x:Class="form.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:form"
        mc:Ignorable="d"
    Title="Chatbot" Height="600" Width="1000" Background="#1E1E1E">
    <Grid>

        <!-- defination of 2 columns :sidebar and main cotent -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <!--Sidebar-->
            <ColumnDefinition Width="*"/>
            <!--main content-->
        </Grid.ColumnDefinitions>

        <!--Sidebar-->
        <StackPanel Background="#2D2D30" Grid.Column="0">

            <Button Content="New Chat"
                    Foreground="White"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    FontSize="16"
                    Margin="10"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Click="NewChat_Click"/>
            <!--Task Assistance-->
            <Button Content="Task Assistance"
                    Foreground="White"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    FontSize="16"
                    Margin="10"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Click="OpenTask_Click"/>
            <!--Cyber Quiz-->
            <Button Content="Cyber Quiz"
                    Foreground="White"
                    BorderBrush="Transparent"
                    Background="Transparent"
                    FontSize="16"
                    Margin="10"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Click="OpenQuiz_Click"/>
            <!--Activity Logs-->
            <Button Content="Activity Logs"
                    Foreground="White"
                    BorderBrush="Transparent"
                    Background="Transparent"
                    FontSize="16"
                    Margin="10"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Click="OpenActivity_Click"/>
            <!--Display history-->
            <TextBlock Text="Chat History" Foreground="LightGray" Margin="10,20,10,5"/>

            <ListBox x:Name="ChatHistory"
                     Background="#2D2D30"
                     Foreground="White"
                     Height="Auto"
                     BorderThickness="0"
                     Margin="10"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <!-- Main Navigation Area -->
        <Frame x:Name="MainFrame"
               Grid.Column="1"
               NavigationUIVisibility="Hidden"/>


    </Grid>
</Window>

