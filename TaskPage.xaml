<Page x:Class="form.TaskPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:form"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="TaskPage">

    <Grid>
        <!-- Task Assistance Panel-->
        <Border Grid.Column="1" Background="#252526" Padding="10" Margin="20">
            <StackPanel>
                <TextBlock Text="Task Assistant"
                           Foreground="WHite"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <TextBox x:Name="TaskInput"
                         Height="35"
                         Margin="0,0,0,10"
                         Padding="5"
                         Background="#444"
                         Foreground="White"
                         BorderBrush="DarkGray"/>

                <Button Content="Add Task"
                        Height="35"
                        Width="100"
                        Background="#0E76FD"
                        Foreground="White"
                        Click="AddTaskButton_Click"/>

                <ListBox x:Name="TaskList"
                         Background="#2D2D30"
                         Foreground="White"
                         Margin="0, 20,0,0">

                </ListBox>


            </StackPanel>
        </Border>
        
    </Grid>
</Page>
