<Page x:Class="form.Quiz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:form"
      mc:Ignorable="d"
      Loaded="Page_Loaded"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Quiz">

    <Grid Margin="20">
        <Border Background="#252526" CornerRadius="10" Padding="20">
            <StackPanel>
                <!-- Title -->
                <TextBlock Text="Cybersecurity Quiz"
                           FontSize="24"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"/>

                <!-- Question -->
                <TextBlock x:Name="QuestionText"
                           FontSize="18"
                           Foreground="White"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <!-- Options -->
                <StackPanel Margin="10,0">
                    <RadioButton x:Name="OptionA" GroupName="QuizOptions" Foreground="White" Margin="0,5"/>
                    <RadioButton x:Name="OptionB" GroupName="QuizOptions" Foreground="White" Margin="0,5"/>
                    <RadioButton x:Name="OptionC" GroupName="QuizOptions" Foreground="White" Margin="0,5"/>
                    <RadioButton x:Name="OptionD" GroupName="QuizOptions" Foreground="White" Margin="0,5"/>
                </StackPanel>

                <!-- Feedback Text -->
                <TextBlock x:Name="ResultText"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,15,0,0"
                           Foreground="LightGreen"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Submit Answer"
                            Width="130"
                            Height="35"
                            Background="#0E76FD"
                            Foreground="White"
                            Margin="0,0,10,0"
                            Click="SubmitAnswer_Click"/>
                    <Button Content="Next Question"
                            Width="130"
                            Height="35"
                            Background="Gray"
                            Foreground="White"
                            Click="NextQuestion_Click"/>
                </StackPanel>

                <!-- Score -->
                <TextBlock x:Name="ScoreText"
                           FontSize="14"
                           Foreground="LightGray"
                           Margin="0,20,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
